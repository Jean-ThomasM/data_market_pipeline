# Mode de stockage : "local" pour écrire dans 02_extract/data/,
# "gcs" pour écrire dans le bucket configuré.
STORAGE=local

# Projet GCP. Actuellement requis par la validation, même en mode local.
GCP_PROJECT_ID=your-gcp-project-id

# Bucket GCS cible. Obligatoire si STORAGE=gcs.
GCS_BUCKET_NAME=your-gcs-bucket-name

# Credentials France Travail.
# Obligatoires en mode local.
# En mode gcs, les secrets sont lus depuis Secret Manager.
FT_CLIENT_ID=your-france-travail-client-id
FT_CLIENT_KEY=your-france-travail-client-key

# Scope OAuth2 France Travail.
SCOPE_API_FT_EMPLOI=api_offresdemploiv2 o2dsoffre

# Cible d'extraction :
# offers | referentials | all
FT_EXTRACT_TARGET=offers

# Paramètres de recherche par défaut.
# Si non défini, le code utilise M1811.
FT_ROME_CODE=M1811

# Utilisé seulement si STORAGE=gcs pour charger un JSON de paramètres
# de recherche depuis le bucket.
FT_SEARCH_PARAMS_OBJECT=config/search_params_gcs.json
