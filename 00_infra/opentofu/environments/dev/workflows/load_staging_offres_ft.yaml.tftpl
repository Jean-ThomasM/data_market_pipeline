main:
  params: [args]
  steps:
    - load_staging_offres_ft:
        call: googleapis.bigquery.v2.jobs.insert
        args:
          projectId: "${project_id}"
          body:
            configuration:
              load:
                destinationTable:
                  projectId: "${project_id}"
                  datasetId: "${dataset_id}"
                  tableId: "${table_id}"
                sourceUris:
                  - "gs://${bucket_name}/raw_offres/*.ndjson"
                sourceFormat: "NEWLINE_DELIMITED_JSON"
                createDisposition: "CREATE_NEVER"
                writeDisposition: "WRITE_TRUNCATE"
                ignoreUnknownValues: true
        result: load_job

    - list_loaded_files:
        call: googleapis.storage.v1.objects.list
        args:
          bucket: "${bucket_name}"
          prefix: "raw_offres/"
          delimiter: "/"
        result: loaded_files

    - move_loaded_files_to_done:
        for:
          value: loaded_file
          in: $${default(loaded_files.items, [])}
          steps:
            - copy_loaded_file:
                call: googleapis.storage.v1.objects.copy
                args:
                  sourceBucket: "${bucket_name}"
                  sourceObject: $${text.url_encode(loaded_file.name)}
                  destinationBucket: "${bucket_name}"
                  destinationObject: $${text.url_encode(text.replace_all(loaded_file.name, "raw_offres/", "raw_offres/done/"))}
                result: copied_file

            - delete_loaded_file:
                call: googleapis.storage.v1.objects.delete
                args:
                  bucket: "${bucket_name}"
                  object: $${text.url_encode(loaded_file.name)}

    - return_result:
        return:
          job_id: $${load_job.jobReference.jobId}
          source_uri: "gs://${bucket_name}/raw_offres/*.ndjson"
          done_prefix: "gs://${bucket_name}/raw_offres/done/"
          destination_table: "${project_id}.${dataset_id}.${table_id}"
