main:
  params: [args]
  steps:
    - load_regions:
        call: googleapis.bigquery.v2.jobs.insert
        args:
          projectId: "${project_id}"
          body:
            configuration:
              load:
                destinationTable:
                  projectId: "${project_id}"
                  datasetId: "${dataset_id}"
                  tableId: "staging_regions"
                sourceUris:
                  - "gs://${bucket_name}/raw_geo/regions.ndjson"
                sourceFormat: "NEWLINE_DELIMITED_JSON"
                createDisposition: "CREATE_NEVER"
                writeDisposition: "WRITE_TRUNCATE"
        result: load_regions_job

    - load_departements:
        call: googleapis.bigquery.v2.jobs.insert
        args:
          projectId: "${project_id}"
          body:
            configuration:
              load:
                destinationTable:
                  projectId: "${project_id}"
                  datasetId: "${dataset_id}"
                  tableId: "staging_departements"
                sourceUris:
                  - "gs://${bucket_name}/raw_geo/departements.ndjson"
                sourceFormat: "NEWLINE_DELIMITED_JSON"
                createDisposition: "CREATE_NEVER"
                writeDisposition: "WRITE_TRUNCATE"
        result: load_departements_job

    - load_communes:
        call: googleapis.bigquery.v2.jobs.insert
        args:
          projectId: "${project_id}"
          body:
            configuration:
              load:
                destinationTable:
                  projectId: "${project_id}"
                  datasetId: "${dataset_id}"
                  tableId: "staging_communes"
                sourceUris:
                  - "gs://${bucket_name}/raw_geo/communes.ndjson"
                sourceFormat: "NEWLINE_DELIMITED_JSON"
                createDisposition: "CREATE_NEVER"
                writeDisposition: "WRITE_TRUNCATE"
        result: load_communes_job

    - load_epcis:
        call: googleapis.bigquery.v2.jobs.insert
        args:
          projectId: "${project_id}"
          body:
            configuration:
              load:
                destinationTable:
                  projectId: "${project_id}"
                  datasetId: "${dataset_id}"
                  tableId: "staging_epcis"
                sourceUris:
                  - "gs://${bucket_name}/raw_geo/epcis.ndjson"
                sourceFormat: "NEWLINE_DELIMITED_JSON"
                createDisposition: "CREATE_NEVER"
                writeDisposition: "WRITE_TRUNCATE"
        result: load_epcis_job

    - list_loaded_files:
        call: googleapis.storage.v1.objects.list
        args:
          bucket: "${bucket_name}"
          prefix: "raw_geo/"
          delimiter: "/"
        result: loaded_files

    - move_loaded_files_to_done:
        for:
          value: loaded_file
          in: $${default(loaded_files.items, [])}
          steps:
            - copy_loaded_file:
                call: googleapis.storage.v1.objects.copy
                args:
                  sourceBucket: "${bucket_name}"
                  sourceObject: $${text.url_encode(loaded_file.name)}
                  destinationBucket: "${bucket_name}"
                  destinationObject: $${text.url_encode(text.replace_all(loaded_file.name, "raw_geo/", "raw_geo/done/"))}
                result: copied_file

            - delete_loaded_file:
                call: googleapis.storage.v1.objects.delete
                args:
                  bucket: "${bucket_name}"
                  object: $${text.url_encode(loaded_file.name)}

    - return_result:
        return:
          regions_job_id: $${load_regions_job.jobReference.jobId}
          departements_job_id: $${load_departements_job.jobReference.jobId}
          communes_job_id: $${load_communes_job.jobReference.jobId}
          epcis_job_id: $${load_epcis_job.jobReference.jobId}
          dataset_id: "${dataset_id}"
          source_prefix: "gs://${bucket_name}/raw_geo/"
          done_prefix: "gs://${bucket_name}/raw_geo/done/"
